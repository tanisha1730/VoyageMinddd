const logger = require('../utils/logger');

/**
 * SUPER INTELLIGENT Itinerary Builder
 * GUARANTEES all days + Smart restaurant/cafe inclusion
 */
class IntelligentItineraryBuilder {
  
  /**
   * Build complete itinerary - GUARANTEED all days!
   */
  buildItinerary(destination, days, budget, interests, allPlaces, placesPerDay = 7) {
    logger.info(`🎯 SUPER INTELLIGENT: Building ${days}-day itinerary for ${destination}`);
    logger.info(`💰 Budget: $${budget} ($${Math.floor(budget/days)}/day)`);
    logger.info(`📍 Total places: ${allPlaces.length}`);
    logger.info(`🎯 Places per day: ${placesPerDay}`);
    
    // Categorize places
    const categorized = this.categorizePlaces(allPlaces);
    logger.info(`📊 Attractions: ${categorized.attractions.length}, Restaurants: ${categorized.restaurants.length}`);
    
    const dailyBudget = Math.floor(budget / days);
    const budgetLevel = this.getBudgetLevel(dailyBudget);
    
    // Separate activities from restaurants
    const activities = [...categorized.attractions, ...categorized.nature, 
                       ...categorized.shopping, ...categorized.viewpoints];
    const restaurants = categorized.restaurants;
    
    // Remove duplicates
    const uniqueActivities = this.removeDuplicates(activities);
    const uniqueRestaurants = this.removeDuplicates(restaurants);
    
    logger.info(`🎯 Unique activities: ${uniqueActivities.length}, Unique restaurants: ${uniqueRestaurants.length}`);
    
    // Shuffle for variety
    this.shuffleArray(uniqueActivities);
    this.shuffleArray(uniqueRestaurants);
    
    const itinerary = [];
    const usedPlaceIds = new Set(); // Track used places to avoid repeats
    
    // Build EVERY day (GUARANTEED!)
    for (let day = 1; day <= days; day++) {
      const result = this.buildDay(
        day, destination, dailyBudget, budgetLevel,
        uniqueActivities, uniqueRestaurants,
        usedPlaceIds,
        day === 1, day === days,
        placesPerDay
      );
      
      itinerary.push(result.dayData);
      
      logger.info(`✅ Day ${day}: ${result.dayData.places.length} items, $${result.dayData.total_cost}`);
    }
    
    return itinerary;
  }
  
  /**
   * Build a single day - GUARANTEED to return a day with EXACT number of places!
   */
  buildDay(day, destination, dailyBudget, budgetLevel, activities, restaurants, 
           usedPlaceIds, isFirst, isLast, placesPerDay = 7) {
    
    const places = [];
    let totalCost = 0;
    
    // Meal costs
    const meals = {
      low: { breakfast: 12, lunch: 20, dinner: 30 },
      medium: { breakfast: 20, lunch: 35, dinner: 70 },
      high: { breakfast: 35, lunch: 55, dinner: 150 }
    }[budgetLevel];
    
    // Helper to get next UNUSED activity (NO FALLBACKS - returns null if none available)
    const getActivity = () => {
      if (activities.length === 0) return null;
      
      // Find first unused activity
      for (let i = 0; i < activities.length; i++) {
        const activity = activities[i];
        if (!usedPlaceIds.has(activity.place_id)) {
          usedPlaceIds.add(activity.place_id);
          return activity;
        }
      }
      
      // NO FALLBACK - return null if all used
      return null;
    };
    
    // Helper to get next UNUSED restaurant (NO FALLBACKS - returns null if none available)
    const getRestaurant = () => {
      if (restaurants.length === 0) return null;
      
      // Find first unused restaurant
      for (let i = 0; i < restaurants.length; i++) {
        const restaurant = restaurants[i];
        if (!usedPlaceIds.has(restaurant.place_id)) {
          usedPlaceIds.add(restaurant.place_id);
          return restaurant;
        }
      }
      
      // NO FALLBACK - return null if all used
      return null;
    };
    
    // Calculate how many activities we need (excluding meals)
    // placesPerDay includes: breakfast, lunch, dinner, and activities
    // So activities = placesPerDay - 3 meals
    let numActivities = Math.max(1, placesPerDay - 3);
    
    // Add arrival/departure if needed
    if (isFirst) numActivities--;
    if (isLast) numActivities--;
    
    let currentTime = 8; // Start at 8 AM
    
    // 1. ARRIVAL (Day 1 only)
    if (isFirst) {
      places.push({
        place_id: `arrival_${day}`,
        name: `Arrive in ${destination}`,
        start_time: '06:00',
        end_time: '08:00',
        activity_type: 'arrival',
        category: ['logistics'],
        description: `✈️ Welcome to ${destination}! Check into hotel and freshen up.`,
        entry_fee: 0,
        rating: 0,
        tags: ['arrival']
      });
    }
    
    // 2. BREAKFAST
    const breakfast = getRestaurant();
    places.push({
      ...breakfast,
      place_id: breakfast.place_id || `breakfast_${day}`,
      start_time: `${String(currentTime).padStart(2, '0')}:00`,
      end_time: `${String(currentTime + 1).padStart(2, '0')}:00`,
      activity_type: 'breakfast',
      description: `☕ Breakfast at ${breakfast.name}`,
      entry_fee: meals.breakfast,
      notes: `Budget: $${meals.breakfast}/person`
    });
    totalCost += meals.breakfast;
    currentTime += 1.5; // 1.5 hours for breakfast + travel
    
    // 3. ACTIVITIES (dynamically create based on numActivities)
    const activityDuration = 2.5; // Each activity takes ~2.5 hours
    const lunchTime = 12.5; // Lunch at 12:30
    const dinnerTime = 20.5; // Dinner at 20:30
    
    let activitiesBeforeLunch = Math.floor(numActivities / 3);
    let activitiesAfterLunch = Math.floor(numActivities / 3);
    let activitiesBeforeDinner = numActivities - activitiesBeforeLunch - activitiesAfterLunch;
    
    // Morning activities (before lunch)
    for (let i = 0; i < activitiesBeforeLunch; i++) {
      const activity = getActivity();
      const startHour = Math.floor(currentTime);
      const startMin = Math.round((currentTime - startHour) * 60);
      const endTime = currentTime + activityDuration;
      const endHour = Math.floor(endTime);
      const endMin = Math.round((endTime - endHour) * 60);
      
      places.push({
        ...activity,
        place_id: activity.place_id || `activity_${day}_${i}`,
        start_time: `${String(startHour).padStart(2, '0')}:${String(startMin).padStart(2, '0')}`,
        end_time: `${String(endHour).padStart(2, '0')}:${String(endMin).padStart(2, '0')}`,
        activity_type: 'morning',
        description: `🏛️ ${activity.description || activity.name}`,
        notes: `Entry: $${activity.entry_fee || 0}`
      });
      totalCost += activity.entry_fee || 0;
      currentTime = endTime;
    }
    
    // 4. LUNCH
    currentTime = lunchTime;
    const lunch = getRestaurant();
    places.push({
      ...lunch,
      place_id: lunch.place_id || `lunch_${day}`,
      start_time: '12:30',
      end_time: '14:00',
      activity_type: 'lunch',
      description: `🍽️ Lunch at ${lunch.name}`,
      entry_fee: meals.lunch,
      notes: `Budget: $${meals.lunch}`
    });
    totalCost += meals.lunch;
    currentTime = 14;
    
    // Afternoon activities (after lunch, before dinner)
    for (let i = 0; i < activitiesAfterLunch; i++) {
      const activity = getActivity();
      const startHour = Math.floor(currentTime);
      const startMin = Math.round((currentTime - startHour) * 60);
      const endTime = currentTime + activityDuration;
      const endHour = Math.floor(endTime);
      const endMin = Math.round((endTime - endHour) * 60);
      
      places.push({
        ...activity,
        place_id: activity.place_id || `activity_${day}_afternoon_${i}`,
        start_time: `${String(startHour).padStart(2, '0')}:${String(startMin).padStart(2, '0')}`,
        end_time: `${String(endHour).padStart(2, '0')}:${String(endMin).padStart(2, '0')}`,
        activity_type: 'afternoon',
        description: `🌆 ${activity.description || activity.name}`,
        notes: `Entry: $${activity.entry_fee || 0}`
      });
      totalCost += activity.entry_fee || 0;
      currentTime = endTime;
    }
    
    // Evening activities (before dinner)
    for (let i = 0; i < activitiesBeforeDinner; i++) {
      const activity = getActivity();
      const startHour = Math.floor(currentTime);
      const startMin = Math.round((currentTime - startHour) * 60);
      const endTime = currentTime + activityDuration;
      const endHour = Math.floor(endTime);
      const endMin = Math.round((endTime - endHour) * 60);
      
      places.push({
        ...activity,
        place_id: activity.place_id || `activity_${day}_evening_${i}`,
        start_time: `${String(startHour).padStart(2, '0')}:${String(startMin).padStart(2, '0')}`,
        end_time: `${String(endHour).padStart(2, '0')}:${String(endMin).padStart(2, '0')}`,
        activity_type: 'evening',
        description: `🌙 ${activity.description || activity.name}`,
        notes: `Entry: $${activity.entry_fee || 0}`
      });
      totalCost += activity.entry_fee || 0;
      currentTime = endTime;
    }
    
    // 5. DINNER
    const dinner = getRestaurant();
    places.push({
      ...dinner,
      place_id: dinner.place_id || `dinner_${day}`,
      start_time: '20:30',
      end_time: '22:00',
      activity_type: 'dinner',
      description: `🍷 Dinner at ${dinner.name}`,
      entry_fee: meals.dinner,
      notes: `Budget: $${meals.dinner}`
    });
    totalCost += meals.dinner;
    
    // 6. DEPARTURE (Last day only)
    if (isLast) {
      places.push({
        place_id: `departure_${day}`,
        name: 'Departure',
        start_time: '22:00',
        end_time: '23:00',
        activity_type: 'departure',
        category: ['logistics'],
        description: `✈️ Pack and prepare for departure`,
        entry_fee: 0,
        rating: 0,
        tags: ['departure']
      });
    }
    
    const theme = this.getTheme(day, isFirst, isLast);
    
    return {
      dayData: {
        day,
        theme: theme.name,
        theme_description: theme.description,
        emoji: theme.emoji,
        places,
        total_cost: Math.round(totalCost),
        budget_remaining: Math.round(dailyBudget - totalCost),
        summary: `Day ${day}: ${theme.description} - ${places.length} places`
      }
    };
  }
  
  /**
   * Categorize places by type
   */
  categorizePlaces(places) {
    const isAttraction = (p) => {
      const cats = (p.category || []).map(c => c.toLowerCase());
      const tags = (p.tags || []).map(t => t.toLowerCase());
      return cats.some(c => ['museum', 'landmark', 'monument', 'tourist_attraction', 
                             'historic', 'castle', 'palace', 'temple', 'church'].includes(c)) ||
             tags.some(t => ['famous', 'iconic', 'must_see'].includes(t));
    };
    
    const isRestaurant = (p) => {
      const cats = (p.category || []).map(c => c.toLowerCase());
      return cats.some(c => ['restaurant', 'cafe', 'food', 'dining'].includes(c));
    };
    
    const isNature = (p) => {
      const cats = (p.category || []).map(c => c.toLowerCase());
      return cats.some(c => ['park', 'garden', 'nature', 'beach', 'lake'].includes(c));
    };
    
    const isShopping = (p) => {
      const cats = (p.category || []).map(c => c.toLowerCase());
      return cats.some(c => ['shopping', 'market', 'mall'].includes(c));
    };
    
    const isViewpoint = (p) => {
      const cats = (p.category || []).map(c => c.toLowerCase());
      const tags = (p.tags || []).map(t => t.toLowerCase());
      return cats.some(c => ['viewpoint', 'tower', 'observation'].includes(c)) ||
             tags.some(t => ['views', 'panoramic'].includes(t));
    };
    
    return {
      attractions: places.filter(isAttraction),
      restaurants: places.filter(isRestaurant),
      nature: places.filter(isNature),
      shopping: places.filter(isShopping),
      viewpoints: places.filter(isViewpoint)
    };
  }
  
  /**
   * Remove duplicate places
   */
  removeDuplicates(places) {
    const seen = new Map();
    places.forEach(p => {
      if (!seen.has(p.place_id)) {
        seen.set(p.place_id, p);
      }
    });
    return Array.from(seen.values());
  }
  
  /**
   * Shuffle array
   */
  shuffleArray(array) {
    for (let i = array.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [array[i], array[j]] = [array[j], array[i]];
    }
  }
  
  /**
   * Get budget level
   */
  getBudgetLevel(dailyBudget) {
    if (dailyBudget < 100) return 'low';
    if (dailyBudget < 300) return 'medium';
    return 'high';
  }
  
  /**
   * Get day theme
   */
  getTheme(day, isFirst, isLast) {
    if (isFirst) return { name: 'Arrival & Exploration', description: 'Getting oriented', emoji: '❤️' };
    if (isLast) return { name: 'Farewell', description: 'Final experiences', emoji: '💞' };
    
    const themes = [
      { name: 'Culture', description: 'Museums and heritage', emoji: '🎨' },
      { name: 'Nature', description: 'Parks and outdoors', emoji: '🌿' },
      { name: 'Local Life', description: 'Authentic experiences', emoji: '🍜' }
    ];
    return themes[(day - 2) % themes.length];
  }
  
}

module.exports = new IntelligentItineraryBuilder();
